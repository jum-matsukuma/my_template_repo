{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Bash(npm test)",
      "Bash(npm install)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(npm run dev)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git show:*)",
      "Bash(git merge-file:*)",
      "Bash(git rev-list:*)",
      "Bash(uv sync:*)",
      "Bash(uv run python -m pytest:*)",
      "Bash(uv run python -m ruff:*)",
      "Bash(uv run python -m black:*)",
      "Bash(uv run python -m mypy:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(bash .claude/scripts/codex-run.sh:*)",
      "Bash(codex --version)",
      "WebFetch(domain:github.com)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  }
}
